        <SolidColorBrush x:Key="BorderBrush"       Color="#233028"/>
        <SolidColorBrush x:Key="BorderLitBrush"    Color="#2e4038"/>
        <SolidColorBrush x:Key="AccentBrush"       Color="#39ff6a"/>
        <SolidColorBrush x:Key="AccentDimBrush"    Color="#2239ff6a"/>
        <SolidColorBrush x:Key="ConnectBtnBrush"   Color="#bf5936"/>
        <SolidColorBrush x:Key="ConnectBtnHBrush"  Color="#d96840"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"  Color="#e8e2da"/>
        <SolidColorBrush x:Key="TextSecondBrush"   Color="#a8b8b0"/>
        <SolidColorBrush x:Key="TextDimBrush"      Color="#607068"/>
        <SolidColorBrush x:Key="TextVeryDimBrush"  Color="#384840"/>
        <SolidColorBrush x:Key="TabActiveBgBrush"  Color="#253c2e"/>
