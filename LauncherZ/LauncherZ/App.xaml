        <SolidColorBrush x:Key="TagVanTxtBrush"    Color="#5edd80"/>
        <SolidColorBrush x:Key="TagModTxtBrush"    Color="#b09ae0"/>
        <SolidColorBrush x:Key="TagOffBgBrush"     Color="#1e7ac4e8"/>
        <SolidColorBrush x:Key="TagVanBgBrush"     Color="#1e5edd80"/>
        <SolidColorBrush x:Key="TagModBgBrush"     Color="#1eb09ae0"/>
        <SolidColorBrush x:Key="TagOffBdrBrush"    Color="#597ac4e8"/>
        <SolidColorBrush x:Key="TagVanBdrBrush"    Color="#595edd80"/>
        <SolidColorBrush x:Key="TagModBdrBrush"    Color="#59b09ae0"/>
        <FontFamily x:Key="MonoFont">Consolas, Courier New</FontFamily>
        <FontFamily x:Key="UIFont">Segoe UI, Arial</FontFamily>
        <FontFamily x:Key="DisplayFont">Segoe UI Semibold, Arial</FontFamily>
    </Application.Resources>
</Application>
