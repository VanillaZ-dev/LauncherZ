<Application x:Class="LauncherZ.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BgRootBrush"       Color="#0d1210"/>
        <SolidColorBrush x:Key="BgPanelBrush"      Color="#161e1a"/>
        <SolidColorBrush x:Key="BgRaisedBrush"     Color="#1c2822"/>
